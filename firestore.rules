rules_version = '2';
// Teacher access to student profiles and grades uses students.teacherIds (kept in sync from course rosters in app code).
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    function userRef() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return exists(userRef());
    }

    function getUserRole() {
      return userDocExists() ? get(userRef()).data.role : null;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    function isTeacher() {
      return request.auth != null && getUserRole() == 'teacher';
    }

    function isStudentRole() {
      return request.auth != null && getUserRole() == 'student';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function userStudentProfileId() {
      return userDocExists() && get(userRef()).data.keys().hasAll(['studentProfileId'])
        ? get(userRef()).data.studentProfileId
        : null;
    }

    function isStudentEnrolledInCourse(courseId) {
      let pid = userStudentProfileId();
      let course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      return isStudentRole() &&
        pid != null &&
        course.keys().hasAll(['studentIds']) &&
        course.studentIds.hasAny([pid]);
    }

    function assessmentPublished(courseId, assessmentId) {
      let a = get(/databases/$(database)/documents/courses/$(courseId)/assessments/$(assessmentId)).data;
      return a.status == 'published';
    }

    // Teacher may only add/update studentProfileId on existing student accounts (registration link)
    function isTeacherLinkingStudentProfile() {
      return isTeacher() &&
        resource.data.role == 'student' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentProfileId']);
    }

    function studentTeacherIdsDoc(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data;
    }

    function teacherLinkedToStudent(studentId) {
      let sd = studentTeacherIdsDoc(studentId);
      return sd.keys().hasAll(['teacherIds']) &&
        sd.teacherIds.hasAny([request.auth.uid]);
    }

    // ==================== USER PROFILE RULES ====================

    match /users/{uid} {
      allow read: if isAuthenticated() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (isTeacher() && resource.data.role == 'student')
      );

      allow create: if isAuthenticated() && request.auth.uid == uid &&
        request.resource.data.role == 'student' &&
        request.resource.data.keys().hasAll(['email', 'role', 'createdAt', 'legalAcceptance']) &&
        request.resource.data.legalAcceptance.keys().hasAll(['termsVersion', 'privacyVersion', 'userAgent', 'acceptedAt']) &&
        request.resource.data.legalAcceptance.acceptedAt == request.time;

      allow update: if isAuthenticated() && (
        (request.auth.uid == uid &&
          !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
          !('studentProfileId' in request.resource.data.diff(resource.data).affectedKeys())) ||
        isAdmin() ||
        isTeacherLinkingStudentProfile()
      );

      allow delete: if isAdmin();
    }

    // ==================== STUDENT DATA RULES ====================

    match /students/{studentId} {

      function isOwner() {
        return request.auth.uid == resource.data.parentUid ||
          request.auth.uid == resource.data.studentUid;
      }

      allow read: if isAuthenticated() && (
        isAdmin() ||
        isOwner() ||
        (isTeacher() && resource.data.keys().hasAll(['teacherIds']) && resource.data.teacherIds.hasAny([request.auth.uid]))
      );

      // Profile edits and roster-driven teacherIds updates use app-layer checks; grade/attendance are rule-scoped below.
      allow create: if isAdmin() || isTeacher();

      allow update, delete: if isAdmin() || isTeacher();

      match /grades/{gradeId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isTeacher() && teacherLinkedToStudent(studentId)) ||
          get(/databases/$(database)/documents/students/$(studentId)).data.parentUid == request.auth.uid ||
          get(/databases/$(database)/documents/students/$(studentId)).data.studentUid == request.auth.uid
        );

        allow create, update, delete: if isAdmin() || (isTeacher() && teacherLinkedToStudent(studentId));
      }

      match /attendance/{attendanceId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isTeacher() && teacherLinkedToStudent(studentId)) ||
          get(/databases/$(database)/documents/students/$(studentId)).data.parentUid == request.auth.uid ||
          get(/databases/$(database)/documents/students/$(studentId)).data.studentUid == request.auth.uid
        );

        allow create, update, delete: if isAdmin() || (isTeacher() && teacherLinkedToStudent(studentId));
      }
    }

    // ==================== COURSE RULES ====================

    match /courses/{courseId} {
      function isCourseTeacher() {
        return isTeacher() && request.auth.uid == resource.data.teacherId;
      }

      allow read: if isAuthenticated() && (
        isAdmin() ||
        isCourseTeacher() ||
        isStudentEnrolledInCourse(courseId)
      );

      allow create: if isAdmin() || isTeacher();

      allow update, delete: if isAdmin() || isCourseTeacher();

      match /assessments/{assessmentId} {

        function isAssessmentTeacher() {
          return request.auth != null && (
            isAdmin() ||
            get(/databases/$(database)/documents/courses/$(courseId)).data.teacherId == request.auth.uid
          );
        }

        allow read: if isAuthenticated() && (
          isAssessmentTeacher() ||
          (assessmentPublished(courseId, assessmentId) && isStudentEnrolledInCourse(courseId))
        );

        allow create, update, delete: if isAssessmentTeacher();

        match /questions/{questionId} {
          allow read: if isAuthenticated() && (
            isAssessmentTeacher() ||
            (assessmentPublished(courseId, assessmentId) && isStudentEnrolledInCourse(courseId))
          );

          allow create, update, delete: if isAssessmentTeacher();
        }

        match /submissions/{studentProfileId} {

          function isOwnSubmission() {
            let studentDoc = get(/databases/$(database)/documents/students/$(studentProfileId));
            return studentDoc != null && (
              studentDoc.data.studentUid == request.auth.uid ||
              studentDoc.data.parentUid == request.auth.uid
            );
          }

          allow read: if isAuthenticated() && (
            isAssessmentTeacher() ||
            isOwnSubmission()
          );

          allow create: if isAuthenticated() && isOwnSubmission();

          allow update: if isAuthenticated() && (
            isAssessmentTeacher() ||
            (isOwnSubmission() && resource.data.status == 'in_progress')
          );

          allow delete: if isAdmin();
        }
      }
    }
  }
}
