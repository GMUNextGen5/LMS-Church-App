rules_version = '2';
// Teacher access to student profiles and grades uses students.teacherIds (kept in sync from course rosters in app code).
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    function userRef() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userDocExists() {
      return exists(userRef());
    }

    function getUserRole() {
      return userDocExists() ? get(userRef()).data.role : null;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    function isTeacher() {
      return request.auth != null && getUserRole() == 'teacher';
    }

    function isStudentRole() {
      return request.auth != null && getUserRole() == 'student';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function userStudentProfileId() {
      return userDocExists() && get(userRef()).data.keys().hasAll(['studentProfileId'])
        ? get(userRef()).data.studentProfileId
        : null;
    }

    function isStudentEnrolledInCourse(courseId) {
      let pid = userStudentProfileId();
      let course = get(/databases/$(database)/documents/courses/$(courseId)).data;
      return isStudentRole() &&
        pid != null &&
        course.keys().hasAll(['studentIds']) &&
        (course.studentIds.hasAny([pid]) ||
          course.studentIds.hasAny([request.auth.uid]));
    }

    function assessmentPublished(courseId, assessmentId) {
      let a = get(/databases/$(database)/documents/courses/$(courseId)/assessments/$(assessmentId)).data;
      return a.status == 'published';
    }

    function studentTeacherIdsDoc(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data;
    }

    /**
     * Teacher link writes: `students/{id}` must list the caller and `studentUid` must match `users/{uid}`
     * so a teacher cannot attach another learner's profile to an arbitrary auth account.
     */
    function studentProfileDocAuthorizesTeacher(studentProfileId, userDocUid) {
      let sdata = get(/databases/$(database)/documents/students/$(studentProfileId)).data;
      return sdata.keys().hasAll(['teacherIds', 'studentUid']) &&
        sdata.studentUid == userDocUid &&
        sdata.teacherIds.hasAny([request.auth.uid]);
    }

    function teacherLinkedToStudent(studentId) {
      let sd = studentTeacherIdsDoc(studentId);
      return sd.keys().hasAll(['teacherIds']) &&
        sd.teacherIds.hasAny([request.auth.uid]);
    }

    /** Student-owned profiles must keep signup `acceptedAt` fixed (merge updates may omit nested maps). */
    function studentLegalAcceptanceAcceptedAtUnchanged() {
      return resource.data.role != 'student' ||
        (request.resource.data.keys().hasAll(['legalAcceptance']) &&
          resource.data.keys().hasAll(['legalAcceptance']) &&
          request.resource.data.legalAcceptance.acceptedAt == resource.data.legalAcceptance.acceptedAt);
    }

    // ==================== USER PROFILE RULES ====================

    match /users/{uid} {

      /** Shared schema for self-service and teacher-led student `users/{uid}` creates (no extra top-level or nested keys). */
      function validNewStudentUserFields() {
        return request.resource.data.role == 'student' &&
          request.resource.data.keys().hasOnly(['email', 'role', 'createdAt', 'legalAcceptance']) &&
          request.resource.data.legalAcceptance.keys().hasOnly(['termsVersion', 'privacyVersion', 'userAgent', 'acceptedAt']) &&
          request.resource.data.legalAcceptance.acceptedAt == request.time;
      }

      /** Teacher creates another account's student profile (e.g. merge-create before link, or full onboarding write). */
      function teacherCreatesStudentUser() {
        return isTeacher() &&
          request.auth.uid != uid &&
          validNewStudentUserFields();
      }

      /**
       * Teacher may only set `studentProfileId` on an existing student user, for a `students` doc that lists them.
       * Blocks role changes and cross-teacher profile hijacking.
       */
      function teacherLinksStudentProfile() {
        return isTeacher() &&
          request.auth.uid != uid &&
          resource.data.role == 'student' &&
          request.resource.data.role == 'student' &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentProfileId']) &&
          request.resource.data.keys().hasAll(['studentProfileId']) &&
          studentProfileDocAuthorizesTeacher(request.resource.data.studentProfileId, uid);
      }

      /** Owner updates: never `role` or `studentProfileId` (students get `studentProfileId` from staff). */
      function selfServiceUserUpdate() {
        return request.auth.uid == uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']) &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['studentProfileId']) &&
          studentLegalAcceptanceAcceptedAtUnchanged();
      }

      allow read: if isAuthenticated() && (
        request.auth.uid == uid ||
        isAdmin() ||
        (isTeacher() && resource.data.role == 'student')
      );

      allow create: if isAuthenticated() && (
        isAdmin() ||
        (request.auth.uid == uid && validNewStudentUserFields()) ||
        teacherCreatesStudentUser()
      );

      allow update: if isAuthenticated() && (
        isAdmin() ||
        teacherLinksStudentProfile() ||
        selfServiceUserUpdate()
      );

      allow delete: if isAdmin();
    }

    // ==================== STUDENT DATA RULES ====================

    match /students/{studentId} {

      function isOwner() {
        return request.auth.uid == resource.data.parentUid ||
          request.auth.uid == resource.data.studentUid;
      }

      allow read: if isAuthenticated() && (
        isAdmin() ||
        isOwner() ||
        (isTeacher() && resource.data.keys().hasAll(['teacherIds']) && resource.data.teacherIds.hasAny([request.auth.uid]))
      );

      // Profile edits and roster-driven teacherIds updates use app-layer checks; grade/attendance are rule-scoped below.
      allow create: if isAdmin() || isTeacher();

      allow update, delete: if isAdmin() || isTeacher();

      match /grades/{gradeId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isTeacher() && teacherLinkedToStudent(studentId)) ||
          get(/databases/$(database)/documents/students/$(studentId)).data.parentUid == request.auth.uid ||
          get(/databases/$(database)/documents/students/$(studentId)).data.studentUid == request.auth.uid
        );

        allow create, update, delete: if isAdmin() || (isTeacher() && teacherLinkedToStudent(studentId));
      }

      match /attendance/{attendanceId} {
        allow read: if isAuthenticated() && (
          isAdmin() ||
          (isTeacher() && teacherLinkedToStudent(studentId)) ||
          get(/databases/$(database)/documents/students/$(studentId)).data.parentUid == request.auth.uid ||
          get(/databases/$(database)/documents/students/$(studentId)).data.studentUid == request.auth.uid
        );

        allow create, update, delete: if isAdmin() || (isTeacher() && teacherLinkedToStudent(studentId));
      }
    }

    // ==================== COURSE RULES ====================

    match /courses/{courseId} {
      function isCourseTeacher() {
        return isTeacher() && request.auth.uid == resource.data.teacherId;
      }

      /** Student access: linked profile ID or Firebase UID on the class roster (privacy: no broad course listing). */
      function canReadCourseAsStudent() {
        return isStudentRole() &&
          resource.data.keys().hasAll(['studentIds']) &&
          (resource.data.studentIds.hasAny([request.auth.uid]) ||
            (userStudentProfileId() != null &&
              resource.data.studentIds.hasAny([userStudentProfileId()])));
      }

      allow read: if isAuthenticated() && (
        isAdmin() ||
        isCourseTeacher() ||
        canReadCourseAsStudent()
      );

      allow create: if isAdmin() || isTeacher();

      allow update, delete: if isAdmin() || isCourseTeacher();

      match /assessments/{assessmentId} {

        function isAssessmentTeacher() {
          return request.auth != null && (
            isAdmin() ||
            get(/databases/$(database)/documents/courses/$(courseId)).data.teacherId == request.auth.uid
          );
        }

        allow read: if isAuthenticated() && (
          isAssessmentTeacher() ||
          (assessmentPublished(courseId, assessmentId) && isStudentEnrolledInCourse(courseId))
        );

        allow create, update, delete: if isAssessmentTeacher();

        match /questions/{questionId} {
          allow read: if isAuthenticated() && (
            isAssessmentTeacher() ||
            (assessmentPublished(courseId, assessmentId) && isStudentEnrolledInCourse(courseId))
          );

          allow create, update, delete: if isAssessmentTeacher();
        }

        match /submissions/{studentProfileId} {

          function isOwnSubmission() {
            let studentDoc = get(/databases/$(database)/documents/students/$(studentProfileId));
            return studentDoc != null && (
              studentDoc.data.studentUid == request.auth.uid ||
              studentDoc.data.parentUid == request.auth.uid
            );
          }

          allow read: if isAuthenticated() && (
            isAssessmentTeacher() ||
            isOwnSubmission()
          );

          allow create: if isAuthenticated() && isOwnSubmission();

          allow update: if isAuthenticated() && (
            isAssessmentTeacher() ||
            (isOwnSubmission() && resource.data.status == 'in_progress')
          );

          allow delete: if isAdmin();
        }
      }
    }
  }
}
