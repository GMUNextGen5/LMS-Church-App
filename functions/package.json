{
  "name": "lms-functions",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for LMS - Secure AI integration",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.17.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "dotenv": "^17.2.3",
    "typescript": "^5.5.4"
  },
  "private": true
}
